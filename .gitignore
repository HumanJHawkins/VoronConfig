# Ignore everything by default
*

# Allow the main folders and scripts
!config/
!autocommit.sh
!listen_and_sync.sh
!.gitignore

# Ignore Klipper's auto-generated junk inside the config folder
config/printer-*.cfg
config/*.bak
config/*.stow
config/.*

# Ignore specific system files that might be in printer_data
.moonraker.uuid
*.log
*.db
*.json
